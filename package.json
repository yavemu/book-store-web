{
  "name": "book-store-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "docker:build": "docker-compose build",
    "docker:dev": "docker-compose up",
    "docker:dev:build": "docker-compose down && docker-compose up --build -d",
    "docker:dev:detached": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:down:clean": "docker-compose down -v --remove-orphans",
    "docker:logs": "docker-compose logs -f web",
    "docker:status": "docker-compose ps",
    "docker:restart": "docker-compose restart web",
    "docker:clean": "docker-compose down && docker network prune -f && docker system prune -f",
    "docker:shell": "docker-compose exec web sh",
    "docker:exec:build": "docker-compose exec web npm run build",
    "docker:exec:lint": "docker-compose exec web npm run lint"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "next": "15.5.0"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@tailwindcss/postcss": "^4",
    "tailwindcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "15.5.0",
    "@eslint/eslintrc": "^3"
  }
}
